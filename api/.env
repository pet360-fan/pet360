# ===========================================
# PET360 - Railway Production Environment
# ===========================================

# Database - Railway injects this automatically when you add PostgreSQL
# DO NOT set this manually in Railway variables
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# Redis (optional - add if you use Redis)
REDIS_URL=redis://localhost:6379

# API Configuration
NODE_ENV=production
API_PORT=3001

# JWT Authentication (use strong secrets - generate with openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_minimum_32_characters_change_this
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_characters_change_this
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Evolution API (WhatsApp) - update with your deployed Evolution API URL
EVOLUTION_API_URL=https://your-evolution-api.up.railway.app
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_INSTANCE_NAME=pet360_main

# Frontend (your Vercel frontend URL - update after deploying frontend)
FRONTEND_URL=https://your-frontend.vercel.app
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# Optional: Monitoring
SENTRY_DSN=

# Optional: File Storage (local or S3)
STORAGE_TYPE=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=